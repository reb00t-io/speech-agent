# Auto-load the project virtual environment.
# Requires direnv: https://direnv.net/

# Re-evaluate when the venv bootstrap changes.
watch_file scripts/venv.rc

# Bootstrap + install deps (creates ./.venv if missing).
source scripts/venv.rc

# Ensure direnv reliably tracks the venv in your shell.
export VIRTUAL_ENV="$PWD/.venv"
PATH_add "$VIRTUAL_ENV/bin"

# Load local secrets (not committed — set these in CI as environment variables)
[[ -f "$PWD/.envrc.local" ]] && source "$PWD/.envrc.local"

# Application settings
export AUTH_MODE=none   # none | password | auth0  (set AUTH_PASSWORD in .envrc.local for password mode)
export PORT=29999
export PUBLIC_URL="https://speech.reb00t.io"
#export LLM_MODEL="gpt-oss-120b"
export LLM_MODEL="kimi-latest"
#export ASR_MODEL="whisper-large-v3"
export ASR_MODEL="voxtral-mini-3b"
# MISTRAL_API_KEY — set in .envrc.local for Voxtral TTS
#export TTS_VOICE="en_paul_neutral"  # see: GET /v1/audio/voices for available voices
# Barge-in tuning (raise the threshold if the assistant's TTS echoes into the mic):
#export BARGE_IN_THRESHOLD_RMS=800   # min mic loudness (RMS) to interrupt
#export BARGE_IN_MIN_MS=400          # min sustained-loud duration before interrupting
#export DUAL_LLM_ENABLED=true        # false = single plain LLM stream for voice replies

# Long-term memory (memorizer); persisted under the data volume:
#export MEMORY_ENABLED=true
# Retrieval store (Qdrant hybrid search + the `recall` tool). On when memory is
# enabled; embeds via LLM_BASE_URL/embeddings. Turn off to fall back to the
# consolidated-prefix-only behaviour:
#export MEMORY_STORE_ENABLED=true
#export EMBEDDING_MODEL=qwen3-embedding-4b
#export EMBEDDING_DIMENSIONS=1024
#export QDRANT_LOCATION=            # e.g. http://qdrant:6333; empty = local on-disk store
# Shared organization memory (role-gated, cross-agent). Off here; supported for
# downstream integrators:
#export MEMORY_ORG_ENABLED=false
#export MEMORY_MEMBER_ID=           # scopes personal recall (empty = single shared store)
#export MEMORY_ROLE=                # this member's org role (gates org read/write)
#export MEMORY_ORG_PROFILE=         # path or literal; empty = memorizer's shipped template
#export MEMORY_ORG_ROLES=           # comma-separated known roles
#export MEMORY_ORG_WRITER_ROLES=    # comma-separated roles allowed to write org facts
